include $(BOARD_DIR)/firmware/firmware.mk

BOARDINC += $(BOARD_DIR)/generated/controllers/generated

# defines SHORT_BOARD_NAME
include $(BOARD_DIR)/meta-info.env

# this would save some flash while being unable to update WBO controller firmware
DDEFS += -DEFI_WIDEBAND_FIRMWARE_UPDATE=FALSE

//DDEFS += -DEFI_MAIN_RELAY_CONTROL=FALSE

# MCU defines
DDEFS += -DSTM32F407xx

# reduce memory usage monitoring
DDEFS += -DRAM_UNUSED_SIZE=100

DDEFS += -DSTM32_ADC_USE_ADC3=TRUE
# todo: make knock pin software-selectable?
DDEFS += -DEFI_SOFTWARE_KNOCK=TRUE -DSTM32_ADC_USE_ADC3=TRUE
DDEFS += -DKNOCK_SPECTROGRAM=FALSE

# assign critical LED to a non-existent pin if you do not have it on your board
# good old PD14 is still the default value
DDEFS += -DLED_CRITICAL_ERROR_BRAIN_PIN=Gpio::I15

//DDEFS += -DHAL_USE_CAN=FALSE
//DDEFS += -DSTM32_CAN_USE_CAN1=FALSE
DDEFS += -DSTM32_CAN_USE_CAN2=FALSE
//DDEFS += -DSTM32_ADC_USE_ADC1=FALSE
//DDEFS += -DSTM32_ADC_USE_ADC2=FALSE
DDEFS += -DHAL_USE_I2C=FALSE
DDEFS += -DSTM32_I2C_USE_I2C1=FALSE
DDEFS += -DSTM32_I2C_USE_I2C2=FALSE
DDEFS += -DSTM32_I2C_USE_I2C3=FALSE
//DDEFS += -DHAL_USE_SPI=FALSE
DDEFS += -DSTM32_SPI_USE_SPI1=FALSE
DDEFS += -DSTM32_SPI_USE_SPI2=FALSE
//DDEFS += -DSTM32_SPI_USE_SPI3=FALSE
DDEFS += -DHAL_USE_MMC_SPI=FALSE
DDEFS += -DHAL_USE_SDC=FALSE
DDEFS += -DSTM32_UART_USE_USART2=FALSE
DDEFS += -DSTM32_UART_USE_USART3=FALSE
DDEFS += -DSTM32_SERIAL_USE_USART1=FALSE
DDEFS += -DSTM32_SERIAL_USE_USART2=FALSE
DDEFS += -DSTM32_SERIAL_USE_USART3=FALSE
DDEFS += -DSTM32_SERIAL_USE_USART6=FALSE
DDEFS += -DHAL_USE_SERIAL=FALSE

DDEFS += -DHAL_USE_UART=TRUE
DDEFS += -DEFI_USE_UART_DMA=TRUE
DDEFS += -DSTM32_UART_USE_USART1=TRUE
DDEFS += -DSTM32_UART_USART1_PRIORITY=6
DDEFS += -DTS_PRIMARY_UxART_PORT=UARTD1
DDEFS += -DTS_PRIMARY_BAUDRATE=115200
DDEFS += -DEFI_CONSOLE_TX_BRAIN_PIN=Gpio::A10
DDEFS += -DEFI_CONSOLE_RX_BRAIN_PIN=Gpio::A9
DDEFS += -DEFI_UART_CONSOLE_TS=TRUE
DDEFS += -DEFI_CONSOLE_AF=7
DDEFS += -Wno-error

